# Supabase Configuration
# Get these from: https://supabase.com/dashboard -> Your Project -> Settings -> API

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anonymous (public) key
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ============================================
# SETUP INSTRUCTIONS:
# ============================================
# 1. Go to https://supabase.com/dashboard
# 2. Create a new project or select existing
# 3. Go to Settings > API
# 4. Copy the "Project URL" to VITE_SUPABASE_URL
# 5. Copy the "anon public" key to VITE_SUPABASE_ANON_KEY
# 6. Run the SQL schema in supabase/schema.sql in Supabase SQL Editor
# 7. Copy this file to .env.local and fill in your values
# 8. Restart the dev server
